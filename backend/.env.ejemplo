# ============================================
# CONFIGURACIÓN DEL SISTEMA DE PAGOS
# ============================================
# Copia este archivo a .env y completa los valores

# ============================================
# Configuración General
# ============================================
DEBUG=True
PROJECT_NAME="Sistema de Pagos"
VERSION="1.0.0"

# ============================================
# Base de Datos PostgreSQL
# ============================================
# Local: postgresql://usuario:password@localhost:5432/pagos_db
# Render: usar la "External Database URL" del dashboard (postgresql://...@host:5432/pagos_db_zjer)
DATABASE_URL=postgresql://usuario:password@localhost:5432/pagos_db

# ============================================
# Seguridad - JWT
# ============================================
SECRET_KEY=tu-clave-secreta-super-segura-aqui-cambiar-en-produccion
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# WhatsApp / Meta Business API
# ============================================
# ⚠️ IMPORTANTE: Crea un token seguro y úsalo también en Meta Developers
# Ejemplo: rapicredit_2024_secure_token_xyz123
WHATSAPP_VERIFY_TOKEN=tu_token_de_verificacion_aqui

# 🔑 Obtener en: Meta Developers > Tu App > WhatsApp > API Setup
# Busca "Token de acceso temporal" o genera uno permanente
WHATSAPP_ACCESS_TOKEN=tu_access_token_de_meta_aqui

# ✅ Ya tienes este valor: 953020801227915
WHATSAPP_PHONE_NUMBER_ID=953020801227915

# ✅ Ya tienes este valor: 1668996594067091
WHATSAPP_BUSINESS_ACCOUNT_ID=1668996594067091

# ============================================
# Email (SMTP) - Opcional
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASSWORD=tu_password_de_aplicacion
SMTP_FROM_EMAIL=tu_email@gmail.com

# ============================================
# AI / OpenRouter (Configuración > tab AI)
# ============================================
# La clave NUNCA se expone al frontend; configúrala en el dashboard (Render, etc.).
# Obtener en: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-tu-clave-aqui

# Modelo por defecto (opcional). Ej: openai/gpt-4o-mini, google/gemini-2.0-flash-001
OPENROUTER_MODEL=openai/gpt-4o-mini

# ============================================
# Redis (Cache - Opcional)
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# Sentry (Monitoreo - Opcional)
# ============================================
SENTRY_DSN=tu_sentry_dsn_aqui

# ============================================
# CORS
# ============================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ============================================
# URL publica del backend (OAuth redirect_uri, enlaces comprobante Excel Gmail)
# ============================================
# Sin barra final. Ej.: https://tu-api.onrender.com
# Vacio = relativo en Excel hasta que configure en despliegue (ver logs PAGOS_GMAIL).
BACKEND_PUBLIC_URL=

# ============================================
# Tareas programadas (servidor) y documentacion API
# ============================================
# false (defecto en codigo): al arrancar NO se inician cron internos (APScheduler:
# finiquito 02:00, auditoria cartera 03:00, limpieza codigos, Gmail programado si aplica),
# liquidado 21:00 Caracas, refresco cache dashboard 1:00/13:00, watcher de lider.
# true: activar cron en el proceso lider (despliegue multi-worker segun su runbook).
ENABLE_AUTOMATIC_SCHEDULED_JOBS=false

# false (defecto en codigo): oculta /docs, /redoc y /openapi.json en internet.
# true: exponer documentacion OpenAPI. Tambien visibles si DEBUG=true.
ENABLE_OPENAPI_DOCS=false

# Gmail en horarios fijos (solo si ENABLE_AUTOMATIC_SCHEDULED_JOBS=true). Por defecto false.
# PAGOS_GMAIL_SCHEDULED_SCAN_ENABLED=false

# ============================================
# CRM campanas: sin envio recurrente automatico
# ============================================
# POST /api/v1/crm/campanas/{id}/programar responde 501. Use iniciar-envio manual.

# Gmail: al arranque, marcar syncs "running" como error solo si ENABLE_AUTOMATIC_SCHEDULED_JOBS=true.
# Con false, no se modifica la tabla al iniciar (evitar efectos ocultos); desbloquee manualmente en BD si hace falta.
