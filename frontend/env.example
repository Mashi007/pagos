# 🌐 CONFIGURACIÓN DE VARIABLES DE ENTORNO - FRONTEND

# ========================================
# 🔧 CONFIGURACIÓN DE API
# ========================================

# Render / producción (Node, server.js): URL pública del FastAPI para el proxy /api/*.
# Debe ser el RENDER_EXTERNAL_URL del Web Service Python (mismo valor que fromService en render.yaml raíz).
# API_BASE_URL=https://TU-BACKEND.onrender.com
# BACKEND_URL=   (alternativa reconocida por server.js)

# Build Vite (opcional): solo si front y API comparten exactamente el mismo origen en el navegador.
# Si VITE_API_URL apunta a OTRO origen que el del SPA, en runtime se usa base '' y rutas /api (same-origin).
# VITE_API_URL=http://localhost:8000

# Desarrollo local con Vite: URL absoluta del API si el dev server no proxea /api.
# VITE_API_URL=http://localhost:8000

# ========================================
# 🔐 CONFIGURACIÓN DE AUTENTICACIÓN
# ========================================

# Token de autenticación (se genera automáticamente)
# VITE_AUTH_TOKEN=

# Tiempo de expiración del token (en segundos)
VITE_TOKEN_EXPIRY=3600

# ========================================
# 🎨 CONFIGURACIÓN DE UI/UX
# ========================================

# Nombre de la aplicación
VITE_APP_NAME=RapiCredit

# Versión de la aplicación
VITE_APP_VERSION=1.0.1

# Entorno de ejecución
VITE_NODE_ENV=production

# ========================================
# 📊 CONFIGURACIÓN DE MONITOREO
# ========================================

# Habilitar logs de desarrollo
VITE_DEBUG=false

# Habilitar métricas de performance
VITE_ENABLE_METRICS=true

# URL para envío de métricas
# VITE_METRICS_URL=

# ========================================
# 🔒 CONFIGURACIÓN DE SEGURIDAD
# ========================================

# Política de contenido seguro
VITE_CSP_ENABLED=true

# Habilitar HTTPS en producción
VITE_FORCE_HTTPS=true

# ========================================
# 📱 CONFIGURACIÓN DE PWA
# ========================================

# Habilitar Service Worker
VITE_PWA_ENABLED=false

# Nombre del cache
VITE_CACHE_NAME=rapicredit-cache

# ========================================
# 🧪 CONFIGURACIÓN DE TESTING
# ========================================

# URL para testing
# VITE_TEST_API_URL=http://localhost:8000

# Habilitar modo de testing
VITE_TEST_MODE=false

# ========================================
# 📋 INSTRUCCIONES DE USO
# ========================================

# 1. Copia este archivo como .env.local
# 2. Modifica los valores según tu entorno
# 3. Para producción, usa las variables de Render
# 4. Nunca commitees archivos .env con datos reales

# ========================================
# 🌍 VARIABLES DE RENDER.COM
# ========================================

# Estas variables se configuran automáticamente en Render:
# - VITE_API_BASE_URL
# - VITE_NODE_ENV=production
# - VITE_APP_NAME
# - VITE_APP_VERSION
